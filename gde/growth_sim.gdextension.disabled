[configuration]

entry_symbol = "growth_sim_library_init"
compatibility_minimum = "4.2"
reloadable = true

[libraries]

windows.debug.x86_64 = "res://gde/bin/growth_sim.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://gde/bin/growth_sim.windows.template_release.x86_64.dll"
linux.debug.x86_64 = "res://gde/bin/libgrowth_sim.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://gde/bin/libgrowth_sim.linux.template_release.x86_64.so"
